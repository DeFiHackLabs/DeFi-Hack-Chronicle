    "accountTypes": [
      {
        "id": "EOA",
        "name": "EOA",
        "color": "#A0A0A0",
        "description": "Externally Owned Account"
      },
      {
        "id": "Contract",
        "name": "Contract",
        "color": "#66BB6A",
        "description": "Smart Contract"
      },
      {
        "id": "Multisig",
        "name": "Multisig",
        "color": "#FFA726",
        "description": "Multi-signature Wallet"
      },
      {
        "id": "Exchange",
        "name": "Exchange",
        "color": "#29B6F6",
        "description": "Exchange / Custodial"
      },
      {
        "id": "Unknown",
        "name": "Unknown",
        "color": "#808080",
        "description": "Unknown / Unverified"
      }
    ]
  },
  "$defs": {
    "transactionItem": {
      "type": "object",
      "required": [
        "txHash",
        "blockchain",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "txHash": {
          "type": "string",
          "pattern": "^.{1,128}$",
          "description": "Transaction hash (hex or base58)"
        },
        "blockchain": {
          "type": "string",
          "description": "Blockchain name"
        },
        "role": {
          "type": "string",
          "description": "Role of this transaction (see _metadata.transactionRoles)"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        }
      }
    },
    "attackerItem": {
      "type": "object",
      "required": [
        "address",
        "blockchain",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "description": "Attacker address"
        },
        "blockchain": {
          "type": "string",
          "description": "Blockchain name"
        },
        "role": {
          "type": "string",
          "description": "Role of this attacker (see _metadata.attackerRoles)"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "accountType": {
          "type": "string",
          "enum": [
            "EOA",
            "Contract",
            "Multisig",
            "Exchange",
            "Unknown"
          ],
          "description": "Type of account"
        }
      }
    },
    "victimItem": {
      "type": "object",
      "required": [
        "address",
        "blockchain",
        "role"
      ],
      "additionalProperties": false,
      "properties": {
        "address": {
          "type": "string",
          "description": "Victim address"
        },
        "blockchain": {
          "type": "string",
          "description": "Blockchain name"
        },
        "role": {
          "type": "string",
          "description": "Role of this victim (see _metadata.victimRoles)"
        },
        "description": {
          "type": "string",
          "description": "Optional description"
        },
        "accountType": {
          "type": "string",
          "enum": [
            "EOA",
            "Contract",
            "Multisig",
            "Exchange",
            "Unknown"
          ],
          "description": "Type of account"
        }
      }
    },
    "localeObject": {
      "type": "object",
      "description": "Localized override of translatable fields. Any field present replaces the root equivalent for this locale.",
      "additionalProperties": false,
      "properties": {
        "title": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "rootCause": {
          "type": "string"
        },
        "attackVector": {
          "type": "string"
        },
        "lessons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transactions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/transactionItem"
          }
        },
        "attackers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/attackerItem"
          }
        },
        "victims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/victimItem"
          }
        },
        "estimatedLoss": {
          "type": "object",
          "description": "Localized override of estimatedLoss fields",
          "properties": {
            "note": {
              "type": "string"
            }
          }
        },
        "attackTime": {
          "type": "object",
          "description": "Localized override of attackTime fields",
          "properties": {
            "note": {
              "type": "string"
            }
          }
        }
      }
    }
  },
  "properties": {
    "id": {
      "type": "string",
      "description": "Unique identifier. Format: ProtocolName-YYYYMMDD (e.g., FTX-20221111)",
      "pattern": "^[a-zA-Z0-9]+(-[a-zA-Z0-9]+)*-[0-9]{8}$"
    },
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "Calendar date for sorting (YYYY-MM-DD)"
    },
    "title": {
      "type": "string",
      "description": "Human-readable event title"
    },
    "protocol": {
      "type": "string",
      "description": "Name of the affected protocol"
    },
    "blockchain": {
      "type": "array",
      "description": "Affected blockchains",
      "items": {
        "type": "string"
      }
    },
    "category": {
      "type": "array",
      "description": "Attack categories",
      "items": {
        "type": "string"
      }
    },
    "ecosystem": {
      "type": "string",
      "description": "Ecosystem (see _metadata.ecosystems)"
    },
    "language": {
      "type": "array",
      "description": "Languages used in the protocol (e.g., ['solidity'], ['N/A'])",
      "items": {
        "type": "string"
      }
    },
    "estimatedLoss": {
      "type": "object",
      "required": [
        "totalUSD",
        "breakdown"
      ],
      "additionalProperties": false,
      "properties": {
        "totalUSD": {
          "type": "string",
          "description": "Total estimated loss in USD"
        },
        "breakdown": {
          "type": "array",
          "description": "Asset-level breakdown",
          "items": {
            "type": "object",
            "required": [
              "asset",
              "amount",
              "convertedUSD"
            ],
            "additionalProperties": false,
            "properties": {
              "asset": {
                "type": "string",
                "description": "Asset symbol or name"
              },
              "amount": {
                "type": "string",
                "description": "Amount lost"
              },
              "convertedUSD": {
                "type": "string",
                "description": "USD equivalent at time of incident"
              },
              "note": {
                "type": "string",
                "description": "Optional note about this breakdown item"
              }
            }
          }
        },
        "note": {
          "type": "string",
          "description": "Optional note about loss calculation"
        }
      }
    },
    "attackTime": {
      "type": "object",
      "required": [
        "startTime",
        "endTime",
        "date"
      ],
      "additionalProperties": false,
      "properties": {
        "startTime": {
          "type": "string",
          "format": "date-time",
          "description": "Attack start time (ISO 8601)"
        },
        "endTime": {
          "type": "string",
          "format": "date-time",
          "description": "Attack end time (ISO 8601)"
        },
        "isRange": {
          "type": "boolean",
          "description": "Whether the attack spanned a time range"
        },
        "note": {
          "type": "string",
          "description": "Optional note about timing"
        },
        "date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "description": "Calendar date (YYYY-MM-DD)"
        }
      }
    },
    "transactions": {
      "type": "array",
      "description": "Related transactions",
      "items": {
        "$ref": "#/$defs/transactionItem"
      }
    },
    "attackers": {
      "type": "array",
      "description": "Attacker addresses",
      "items": {
        "$ref": "#/$defs/attackerItem"
      }
    },
    "victims": {
      "type": "array",
      "description": "Victim addresses",
      "items": {
        "$ref": "#/$defs/victimItem"
      }
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the incident"
    },
    "rootCause": {
      "type": "string",
      "description": "Root cause of the exploit"
    },
    "attackVector": {
      "type": "string",
      "description": "How the attack was executed"
    },
    "lessons": {
      "type": "array",
      "description": "Lessons learned",
      "items": {
        "type": "string"
      }
    },
    "references": {
      "type": "array",
      "description": "Reference URLs",
      "items": {
        "type": "string"
      }
    },
    "locales": {
      "type": "object",
      "description": "Optional localization overrides keyed by language code (e.g., 'zh-TW', 'ja')",
      "additionalProperties": {
        "$ref": "#/$defs/localeObject"
      }
    },
    "metadata": {
      "type": "object",
      "required": [
        "human_verified"
      ],
      "additionalProperties": false,
      "properties": {
        "dateAdded": {
          "type": "string",
          "format": "date",
          "description": "Date this record was added"
        },
        "lastUpdated": {
          "type": "string",
          "format": "date",
          "description": "Date of last update"
        },
        "human_verified": {
          "type": "boolean",
          "description": "Whether this record has been human-verified"
        },
        "models": {
          "type": "array",
          "description": "AI models used to generate or verify this record",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
