{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DeFi Hack Event",
  "description": "Strict schema for DeFi hack event records. All objects use additionalProperties: false.",
  "type": "object",
  "required": [
    "id",
    "date",
    "title",
    "protocol",
    "blockchain",
    "category",
    "ecosystem",
    "language",
    "estimatedLoss",
    "attackTime",
    "description",
    "transactions",
    "attackers",
    "victims",
    "rootCause",
    "attackVector",
    "lessons",
    "references",
    "metadata"
  ],
  "additionalProperties": false,
  "_metadata": {
    "fileNamingConvention": "YYYYMMDD-ProtocolName.json",
    "repository": "data/hacks/",
    "extensibleFields": {
      "description": "When no existing key matches, you MAY add a new key to these vocabularies.",
      "fields": [
        "languages",
        "ecosystems",
        "categories",
        "blockchains",
        "attackerRoles",
        "victimRoles",
        "transactionRoles"
      ]
    },
    "categories": [
