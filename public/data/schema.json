        "description": "Polkadot SDK"
      },
      {
        "id": "substrate",
        "name": "Substrate",
        "description": "Substrate Framework"
      },
      {
        "id": "solana",
        "name": "Solana",
        "description": "Solana ecosystem"
      },
      {
        "id": "move",
        "name": "Move",
        "description": "Aptos and Sui ecosystem"
      },
      {
        "id": "ton",
        "name": "TON",
        "description": "Telegram Open Network"
      },
      {
        "id": "bitcoin",
        "name": "Bitcoin",
        "description": "Bitcoin ecosystem"
      },
      {
        "id": "other",
        "name": "Other",
        "description": "Other"
      }
    ],
    "attackerRoles": [
      {
        "id": "gas_funder",
        "name": "Gas Funder",
        "color": "#EF5350",
        "description": "Address that funded the attacker"
      },
      {
        "id": "primary_attacker",
        "name": "Primary Attacker",
        "color": "#FF7043",
        "description": "Primary exploiter"
      },
      {
        "id": "exploit_contract",
        "name": "Exploit Contract",
        "color": "#FFCA28",
        "description": "Exploit contract"
      },
      {
        "id": "consolidation",
        "name": "Consolidation",
        "color": "#42B865",
        "description": "Fund consolidation address"
      },
      {
        "id": "child_dao",
        "name": "Child Dao",
        "color": "#2ED5C1",
        "description": "Child DAO created by exploit"
      }
    ],
    "victimRoles": [
      {
        "id": "protocol",
        "name": "Protocol",
        "color": "#E53935",
        "description": "The attacked protocol itself"
      },
      {
        "id": "user",
        "name": "User",
        "color": "#FB8C00",
        "description": "End users who lost funds"
      },
      {
        "id": "liquidity_pool",
        "name": "Liquidity Pool",
        "color": "#FDD835",
        "description": "Liquidity pool"
      },
      {
        "id": "treasury",
        "name": "Treasury",
        "color": "#50C878",
